---
---

<section id="contact" data-bg-layer="contact" class="min-h-[calc(100svh-4rem)] scroll-mt-16 snap-start bg-transparent py-8 md:py-10 flex items-center">
  <div class="max-w-7xl mx-auto w-full px-4 md:px-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-stretch">
      <!-- Info -->
      <div class="w-full lg:w-1/3 space-y-6 md:space-y-8 flex flex-col justify-center">
        <div class="space-y-2">
          <h2 class="text-[10px] font-mono text-muted-foreground tracking-[0.2em] uppercase">// COMMUNICATION_CHANNEL</h2>
          <h3 class="text-3xl font-mono font-bold tracking-tighter italic">DIRECT_MESSAGE</h3>
        </div>
        <div class="space-y-3 md:space-y-4">
          <a href="mailto:ZRishu@hotmail.com" class="block p-4 border border-border bg-card hover:border-brand-green transition-all group">
            <span class="text-[9px] font-mono text-muted-foreground block mb-1 uppercase tracking-widest">EMAIL_STATION</span>
            <span class="text-sm font-mono text-foreground group-hover:text-brand-green transition-colors">ZRISHU@HOTMAIL.COM</span>
          </a>
          <a href="https://github.com/ZRishu" target="_blank" class="block p-4 border border-border bg-card hover:border-brand-green transition-all group">
            <span class="text-[9px] font-mono text-muted-foreground block mb-1 uppercase tracking-widest">GITHUB_REPOSITORY</span>
            <span class="text-sm font-mono text-foreground group-hover:text-brand-green transition-colors">GITHUB.COM/ZRISHU</span>
          </a>
          <a href="https://linkedin.com/in/ZRishu" target="_blank" class="block p-4 border border-border bg-card hover:border-brand-green transition-all group">
            <span class="text-[9px] font-mono text-muted-foreground block mb-1 uppercase tracking-widest">PROFESSIONAL_NETWORK</span>
            <span class="text-sm font-mono text-foreground group-hover:text-brand-green transition-colors">LINKEDIN.COM/IN/ZRISHU</span>
          </a>
          <a href="https://x.com/ZRishu" target="_blank" class="block p-4 border border-border bg-card hover:border-brand-green transition-all group">
            <span class="text-[9px] font-mono text-muted-foreground block mb-1 uppercase tracking-widest">SOCIAL_CIRCLE</span>
            <span class="text-sm font-mono text-foreground group-hover:text-brand-green transition-colors">X.COM/ZRISHU</span>
          </a>
        </div>
      </div>

      <!-- Form -->
      <div class="w-full lg:w-2/3 border border-border p-6 md:p-10 bg-card flex items-center">
        <form id="contact-form" class="space-y-6 md:space-y-8 w-full">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            <div class="space-y-2 group">
              <label for="sender_name" class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">>> SENDER_NAME</label>
              <input 
                type="text" 
                id="sender_name" 
                name="sender_name" 
                required 
                placeholder="INPUT_NAME" 
                class="w-full bg-transparent border-b border-border py-2 text-sm font-mono text-foreground placeholder:text-muted-foreground transition-colors"
              />
            </div>
            <div class="space-y-2 group">
              <label for="sender_email" class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">>> SENDER_EMAIL</label>
              <input 
                type="email" 
                id="sender_email" 
                name="sender_email" 
                required 
                placeholder="INPUT_EMAIL" 
                class="w-full bg-transparent border-b border-border py-2 text-sm font-mono text-foreground placeholder:text-muted-foreground transition-colors"
              />
            </div>
          </div>
          <div class="space-y-2 group">
            <label for="message_body" class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">>> MESSAGE_PAYLOAD</label>
            <textarea 
              id="message_body" 
              name="message_body" 
              required 
              placeholder="ENTER_MESSAGE_BODY..." 
              rows="4" 
              class="w-full bg-transparent border-b border-border py-2 text-sm font-mono text-foreground placeholder:text-muted-foreground resize-none transition-colors"
            ></textarea>
          </div>
          
          <div id="form-status" class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest min-h-[1.5rem]"></div>
          
          <button 
            type="submit" 
            id="contact-submit"
            class="px-8 py-3 bg-foreground text-background font-mono text-xs font-bold tracking-[0.2em] transition-all uppercase border border-border"
          >
            TRANSMIT_MESSAGE
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm(): void {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const statusEl = document.getElementById("form-status");
    const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;

    if (!form || !statusEl || !submitBtn) return;

    // Validation logic for hover effect
    const validate = () => {
      const inputs = Array.from(form.querySelectorAll('input[required], textarea[required]')) as (HTMLInputElement | HTMLTextAreaElement)[];
      return inputs.every(input => input.value.trim() !== "");
    };

    submitBtn.addEventListener("mouseenter", () => {
      if (validate()) {
        submitBtn.classList.add("bg-brand-green", "text-white");
        submitBtn.classList.remove("bg-foreground", "text-background");
      }
    });

    submitBtn.addEventListener("mouseleave", () => {
      submitBtn.classList.remove("bg-brand-green", "text-white");
      submitBtn.classList.add("bg-foreground", "text-background");
    });

    async function handleSubmit(e: Event): Promise<void> {
      e.preventDefault();
      submitBtn!.disabled = true;
      const originalText = submitBtn!.innerText;
      submitBtn!.innerText = "TRANSMITTING...";
      
      statusEl!.textContent = ">> UPLOADING_PAYLOAD...";
      statusEl!.className = "text-[10px] font-mono text-brand-orange uppercase tracking-widest";

      const formData = new FormData(form!);
      const payload = {
        sender_name: String(formData.get("sender_name") ?? ""),
        sender_email: String(formData.get("sender_email") ?? ""),
        message_body: String(formData.get("message_body") ?? ""),
      };

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const envelope = await res.json();

        if (envelope.success) {
          statusEl!.textContent = ">> SUCCESS: MESSAGE_STATION_ACKNOWLEDGED_200_OK";
          statusEl!.className = "text-[10px] font-mono text-brand-green uppercase tracking-widest font-bold";
          form!.reset();
        } else {
          statusEl!.textContent = `>> ERROR: ${envelope.error?.message ?? "UNKNOWN_EXCEPTION"}`;
          statusEl!.className = "text-[10px] font-mono text-brand-red uppercase tracking-widest";
        }
      } catch {
        statusEl!.textContent = ">> FATAL: NETWORK_HANDSHAKE_FAILED";
        statusEl!.className = "text-[10px] font-mono text-brand-red uppercase tracking-widest";
      } finally {
        submitBtn!.disabled = false;
        submitBtn!.innerText = originalText;
      }
    }

    form.addEventListener("submit", (e: Event) => {
      void handleSubmit(e);
    });
  }

  initContactForm();
</script>
