---

<section id="about" class="about">
  <div class="container">
    <h2 class="section-title">About Me</h2>
    <div class="about-content" id="about-content">
      <div class="about-loading">
        <p>Loading profile from resume…</p>
      </div>
    </div>
  </div>
</section>

<script>
  async function loadAbout(): Promise<void> {
    const contentEl = document.getElementById("about-content");
    if (!contentEl) return;

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          question:
            "Write a brief professional summary (3-4 sentences) of the person in this resume including their key skills, experience, and what they specialize in. Write in first person.",
        }),
      });

      interface ChatEnvelope {
        success: boolean;
        data?: { answer: string };
      }

      const envelope: ChatEnvelope = await res.json() as ChatEnvelope;
      if (envelope.success && envelope.data) {
        contentEl.innerHTML = `<p class="about-text">${escapeHtml(envelope.data.answer.trim())}</p>`;
      } else {
        contentEl.innerHTML = '<p class="about-text about-fallback">About information will appear here once a resume is ingested by the admin.</p>';
      }
    } catch {
      contentEl.innerHTML = '<p class="about-text about-fallback">About information will appear here once the backend is connected and a resume is ingested.</p>';
    }

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          question:
            "List the key technical skills of the person in this resume as a comma-separated list. Reply with ONLY the skills, nothing else.",
        }),
      });

      interface ChatEnvelope {
        success: boolean;
        data?: { answer: string };
      }

      const envelope: ChatEnvelope = await res.json() as ChatEnvelope;
      if (envelope.success && envelope.data) {
        const skills = envelope.data.answer
          .split(",")
          .map((s: string) => s.trim())
          .filter((s: string) => s.length > 0);
        if (skills.length > 0) {
          const skillsHtml = skills
            .map((s: string) => `<span class="skill-tag">${escapeHtml(s)}</span>`)
            .join("");
          const container = document.createElement("div");
          container.className = "skills-container";
          container.innerHTML = `<h3 class="skills-title">Skills</h3><div class="skills-grid">${skillsHtml}</div>`;
          contentEl.appendChild(container);
        }
      }
    } catch {
      // Skills section is optional; silently skip
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  loadAbout();
</script>

<style>
  .about {
    background: var(--color-surface);
  }

  .about-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .about-text {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    text-align: center;
  }

  .about-fallback {
    font-style: italic;
    opacity: 0.7;
  }

  .about-loading {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .skills-container {
    margin-top: 2rem;
  }

  .skills-title {
    text-align: center;
    font-size: 1.125rem;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .skill-tag {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: var(--color-bg);
    color: var(--color-primary);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
  }
</style>
