---
const techStack = [
  "Java", "Spring Boot", "Go", "Python", "C", "Rust", "React", "PostgreSQL", "MongoDB", "Docker", "Kubernetes", "Kafka", "Github Actions", "Git"
];
---

<section id="about" data-bg-layer="about" class="min-h-[calc(100svh-4rem)] scroll-mt-16 snap-start border-b border-border bg-transparent py-8 md:py-10 flex items-center">
  <div class="max-w-7xl mx-auto w-full px-4 md:px-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-center">
      <!-- Left: Identity & Core Details -->
      <div class="w-full lg:w-1/3">
        <div class="border border-border p-6 md:p-8 flex flex-col items-center lg:items-start bg-card">
          <!-- Profile Picture with Mode Toggle -->
          <div 
            id="profile-trigger"
            class="w-40 h-40 md:w-48 md:h-48 border border-border bg-muted mb-6 md:mb-8 flex items-center justify-center grayscale relative cursor-pointer group overflow-hidden"
          >
            <img
              src="/image.webp"
              alt="Profile image"
              class="absolute inset-0 h-full w-full object-cover transition-all duration-500 ease-out group-hover:scale-105 group-hover:opacity-0"
            />
            <img
              src="/jesus.webp"
              alt="Hover image"
              class="absolute inset-0 h-full w-full object-cover opacity-0 transition-all duration-500 ease-out group-hover:opacity-100 group-hover:scale-110 group-hover:-rotate-6 group-hover:translate-x-1 group-hover:-translate-y-1"
            />

            <div id="hover-overlay" class="absolute inset-0 bg-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
              <button
                id="toggle-text"
                type="button"
                class="pointer-events-auto absolute right-2 top-3 max-w-[8rem] -translate-y-1 rounded-full border border-black/20 bg-brand-green px-3 py-2 text-[10px] font-mono font-bold tracking-tighter uppercase leading-tight text-black shadow-[0_10px_30px_rgba(0,163,84,0.25)] transition-all duration-300 ease-out group-hover:-translate-y-2 group-hover:rotate-3 animate-[thoughtFloat_2.2s_ease-in-out_infinite]"
              >
                LET_THERE_BE_LIGHT
              </button>
              <span class="absolute right-8 top-[3.9rem] h-3 w-3 rounded-full bg-brand-green transition-all duration-300 group-hover:right-9 group-hover:top-[4.1rem]"></span>
              <span class="absolute right-5 top-[4.9rem] h-2 w-2 rounded-full bg-brand-green/80 transition-all duration-300 group-hover:right-6 group-hover:top-[5.05rem]"></span>
            </div>
          </div>

          <div class="space-y-4 w-full">
            <div class="border-b border-border pb-2 flex justify-between items-end">
              <span class="text-[10px] font-mono text-muted-foreground tracking-tighter uppercase">IDENTITY_NAME</span>
              <span class="font-mono text-sm font-bold text-brand-green" id="hero-name">Rishu</span>
            </div>
            <div class="border-b border-border pb-2 flex justify-between items-end">
              <span class="text-[10px] font-mono text-muted-foreground tracking-tighter uppercase">PRIMARY_ROLE</span>
              <span class="font-mono text-sm">BACKEND_DEV</span>
            </div>
            <div class="border-b border-border pb-2 flex justify-between items-end">
              <span class="text-[10px] font-mono text-muted-foreground tracking-tighter uppercase">SPECIALIZATION</span>
              <span class="font-mono text-sm text-muted-foreground">JAVA_ECOSYSTEM</span>
            </div>
            <div class="border-b border-border pb-2 flex justify-between items-end">
              <span class="text-[10px] font-mono text-muted-foreground tracking-tighter uppercase">LOCATION</span>
              <span class="font-mono text-sm text-muted-foreground">REMOTE_INDIA</span>
            </div>
            <div class="border-b border-border pb-2 flex justify-between items-end gap-4">
              <span class="text-[10px] font-mono text-muted-foreground tracking-tighter uppercase">EDUCATION</span>
              <span class="font-mono text-sm text-muted-foreground text-right">BTECH_CSE</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Summary & Tech -->
      <div class="w-full lg:w-2/3 space-y-8 md:space-y-10">
        <div class="space-y-4 md:space-y-6">
          <h2 class="text-[10px] font-mono text-muted-foreground tracking-[0.2em] uppercase">// SYSTEM_SUMMARY</h2>
          <div id="hero-tagline" class="text-lg md:text-2xl leading-relaxed font-light text-foreground max-w-2xl">
            <span class="text-brand-orange">></span> Initializing professional data...
            <span class="inline-block w-2 h-5 bg-foreground animate-pulse align-middle ml-1"></span>
          </div>
        </div>

        <div class="space-y-4 md:space-y-6">
          <h2 class="text-[10px] font-mono text-muted-foreground tracking-[0.2em] uppercase">// TECHNICAL_CAPABILITIES</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-px bg-border border border-border">
            {techStack.map(tech => (
              <div class="bg-background p-3 md:p-4 text-[10px] md:text-[11px] font-mono tracking-wider text-muted-foreground hover:text-foreground hover:bg-muted transition-all flex items-center gap-2 group/tech">
                <span class="w-1.5 h-1.5 bg-brand-red opacity-0 group-hover/tech:opacity-100 transition-opacity"></span>
                {tech.toUpperCase()}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes thoughtFloat {
    0%, 100% {
      transform: translateY(-0.35rem) rotate(2deg);
    }
    50% {
      transform: translateY(-0.6rem) rotate(4deg);
    }
  }
</style>

<script>
  import { apiUrl } from "../lib/public-api";

  async function loadHero(): Promise<void> {
    const nameEl = document.getElementById("hero-name");
    const taglineEl = document.getElementById("hero-tagline");
    if (!nameEl || !taglineEl) return;

    const clampWords = (text: string, maxWords: number): string => {
      const words = text.trim().split(/\s+/).filter(Boolean);
      return words.slice(0, maxWords).join(" ");
    };

    const requestAnswer = async (question: string, maxWords?: number): Promise<string | null> => {
      const res = await fetch(apiUrl("/api/chat"), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          question,
          ...(maxWords ? { max_words: maxWords } : {}),
        }),
      });

      const envelope = await res.json();
      return envelope.success && envelope.data?.answer
        ? clampWords(envelope.data.answer, maxWords ?? Number.MAX_SAFE_INTEGER)
        : null;
    };

    try {
      const [name, tagline] = await Promise.all([
        requestAnswer("What is the full name of the person in this resume? Reply with ONLY the name, nothing else."),
        requestAnswer("Write a brief professional summary in under 30 words of the person in this resume. Write in first person. Do not use markdown, keep it as plain text. Focus only on core technical expertise.", 30),
      ]);

      if (name) {
        nameEl.textContent = name;
      }

      if (tagline) {
        taglineEl.innerHTML = `<span class="text-brand-orange">></span> ${tagline}<span class="inline-block w-2 h-5 bg-foreground animate-pulse align-middle ml-1"></span>`;
      }
    } catch {
      taglineEl.innerHTML = `<span class="text-brand-orange">></span> I am a Backend Developer specializing in Java, focusing on building high-performance scalable systems and microservices architectures.<span class="inline-block w-2 h-5 bg-foreground animate-pulse align-middle ml-1"></span>`;
    }
  }

  function initModeToggle(): void {
    const trigger = document.getElementById("profile-trigger");
    const hoverOverlay = document.getElementById("hover-overlay");
    const toggleText = document.getElementById("toggle-text");
    const html = document.documentElement;

    if (!trigger || !hoverOverlay || !toggleText) return;

    const switchToLight = (e: Event): void => {
      if (!html.classList.contains("dark")) return;
      if (typeof (window as any).toggleTheme === 'function') {
        (window as any).toggleTheme(e as MouseEvent, "light");
      }
    };

    // Listen for global theme changes to update UI
    document.addEventListener("theme-changed", (e: any) => {
      if (e.detail.theme === 'light') {
        hoverOverlay.classList.remove("group-hover:opacity-100");
        trigger.style.cursor = "default";
        toggleText.setAttribute("disabled", "true");
      } else {
        hoverOverlay.classList.add("group-hover:opacity-100");
        trigger.style.cursor = "pointer";
        toggleText.removeAttribute("disabled");
      }
    });

    // Check if already in light mode on load
    if (!html.classList.contains("dark")) {
      hoverOverlay.classList.remove("group-hover:opacity-100");
      trigger.style.cursor = "default";
      toggleText.setAttribute("disabled", "true");
      return;
    }

    trigger.addEventListener("click", switchToLight);
    toggleText.addEventListener("click", (e) => {
      e.stopPropagation();
      switchToLight(e);
    });
  }

  loadHero();
  initModeToggle();
</script>
