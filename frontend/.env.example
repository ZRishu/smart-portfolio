# Smart Portfolio Frontend
# Copy to .env for local development or provide these in your deployment platform.

# Public backend API origin for production/static deployments.
# Leave empty in local development when using the Astro dev proxy.
PUBLIC_API_URL=

# Dev-only proxy target used by astro.config.ts.
# Local default: http://localhost:8080
PUBLIC_DEV_API_PROXY=http://localhost:8080

# Optional dev server port override.
FRONTEND_PORT=5173
